# Example environment configuration for Threadsmiitit.
# Copy to .env and fill in real values for local development with `netlify dev`.
# In production these are set as Netlify site environment variables — never commit real values.

# Anthropic API key for the Miitti-apuri chat assistant (netlify/functions/chat.js).
# Read server-side only; never exposed to the browser bundle.
ANTHROPIC_API_KEY=sk-ant-dummy-example-key

# Origin allowed to call /api/chat. Defaults to https://threadsmiitit.netlify.app if unset.
ALLOWED_ORIGIN=http://localhost:8001

# Threads (Meta) OAuth app credentials, used by netlify/functions/auth-login.js
# and netlify/functions/auth-callback.js.
THREADS_CLIENT_ID=dummy-threads-client-id
THREADS_CLIENT_SECRET=dummy-threads-client-secret
THREADS_REDIRECT_URI=http://localhost:8001/api/auth/callback

# Secret key used to HMAC-sign the tm_session cookie (netlify/functions/lib/session.mjs).
# Long random string; rotating it invalidates all existing sessions.
SESSION_SECRET=dummy-session-secret-change-me
