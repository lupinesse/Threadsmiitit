# Example environment configuration for Threadsmiitit.
# Copy to .env and fill in real values for local development with `netlify dev`.
# In production these are set as Netlify site environment variables — never commit real values.

# Anthropic API key for the Miitti-apuri chat assistant (netlify/functions/chat.js).
# Read server-side only; never exposed to the browser bundle.
ANTHROPIC_API_KEY=sk-ant-dummy-example-key

# Origin allowed to call /api/chat. Defaults to https://threadsmiitit.netlify.app if unset.
ALLOWED_ORIGIN=http://localhost:8001

# Threads (Meta) OAuth app credentials, used by netlify/functions/auth-login.js
# and netlify/functions/auth-callback.js.
THREADS_CLIENT_ID=dummy-threads-client-id
THREADS_CLIENT_SECRET=dummy-threads-client-secret
THREADS_REDIRECT_URI=http://localhost:8001/api/auth/callback

# Secret key used to HMAC-sign the tm_session cookie (netlify/functions/lib/session.mjs).
# Long random string; rotating it invalidates all existing sessions.
SESSION_SECRET=dummy-session-secret-change-me

# Sentry DSN for Netlify Functions error monitoring (netlify/functions/lib/sentry.mjs).
# Server-side only. Leave unset to disable — functions run normally without it.
SENTRY_DSN=https://dummy@o0.ingest.sentry.io/0

# Sentry DSN for the browser bundle (src/lib/sentry.js). Vite inlines VITE_-prefixed
# vars into client code, so this value is public by design — a DSN is safe to expose.
# Leave unset to disable — the app runs normally without it.
VITE_SENTRY_DSN=https://dummy@o0.ingest.sentry.io/0

# Sentry API access for the triage script (.github/scripts/sentry-triage.mjs,
# `npm run sentry:triage`). SENTRY_AUTH_TOKEN needs Issue & Event: Read & Write
# scope on a Sentry personal token (organization tokens don't currently support
# issue scopes). Only needed to run the script locally — in CI these come from
# the SENTRY_AUTH_TOKEN secret and SENTRY_ORG/SENTRY_PROJECT/SENTRY_API_HOST
# repository variables (see .github/workflows/sentry-triage.yml). GITHUB_TOKEN
# is read from `gh auth token` when running locally with the gh CLI.
# SENTRY_ORG/SENTRY_PROJECT are the org/project slugs from your Sentry
# project's URL (https://<org>.sentry.io/issues/?project=<numeric-id> —
# the slug itself is under Settings > Projects > <project> > General).
SENTRY_AUTH_TOKEN=dummy-sentry-personal-token
SENTRY_ORG=dummy-sentry-org-slug
SENTRY_PROJECT=dummy-sentry-project-slug

# Sentry API host. Leave unset (defaults to sentry.io) unless your org uses a
# data-residency region other than the US — check Settings > General >
# "Data Storage Region" in Sentry. EU-region orgs use de.sentry.io.
SENTRY_API_HOST=sentry.io

# Threads broadcast bot (netlify/functions/bot-*.js, netlify/functions/lib/
# threadsClient.mjs, botState.mjs, botConfig.mjs). Reuses THREADS_CLIENT_ID/
# THREADS_CLIENT_SECRET/THREADS_REDIRECT_URI above (same Meta app) for the
# bot's one-time authorization via `node scripts/seed-bot-token.mjs`.

# The bot's own Threads user id (numeric) — printed by scripts/seed-bot-token.mjs
# after it authorizes the bot account; set it here (or as a Netlify site env
# var) once you have it.
THREADS_BOT_USER_ID=dummy-bot-user-id

# Master switch. Must be exactly "true" to allow the bot to post anything —
# any other value (including unset) keeps it fully inert. Defaults false.
BOT_ENABLED=false

# When true (the default), bot-* functions log the post they would have made
# instead of calling the Threads API. Must be explicitly "false" to post for
# real — validate with BOT_DRY_RUN=true against production data first.
BOT_DRY_RUN=true

# Needed only to run scripts/seed-bot-token.mjs locally — lets it reach
# Netlify Blobs from outside a deployed function. Site ID is under Site
# configuration > General > Site details; generate a personal access token
# at https://app.netlify.com/user/applications#personal-access-tokens.
NETLIFY_SITE_ID=dummy-netlify-site-id
NETLIFY_API_TOKEN=dummy-netlify-personal-access-token
