# Example environment configuration for Threadsmiitit.
# Copy to .env and fill in real values for local development with `netlify dev`.
# In production these are set as Netlify site environment variables — never commit real values.

# Anthropic API key for the Miitti-apuri chat assistant (netlify/functions/chat.js).
# Read server-side only; never exposed to the browser bundle.
ANTHROPIC_API_KEY=sk-ant-dummy-example-key

# Origin allowed to call /api/chat. Defaults to https://threadsmiitit.netlify.app if unset.
ALLOWED_ORIGIN=http://localhost:8001

# Threads (Meta) OAuth app credentials, used by netlify/functions/auth-login.js
# and netlify/functions/auth-callback.js.
THREADS_CLIENT_ID=dummy-threads-client-id
THREADS_CLIENT_SECRET=dummy-threads-client-secret
THREADS_REDIRECT_URI=http://localhost:8001/api/auth/callback

# Secret key used to HMAC-sign the tm_session cookie (netlify/functions/lib/session.mjs).
# Long random string; rotating it invalidates all existing sessions.
SESSION_SECRET=dummy-session-secret-change-me

# Sentry DSN for Netlify Functions error monitoring (netlify/functions/lib/sentry.mjs).
# Server-side only. Leave unset to disable — functions run normally without it.
SENTRY_DSN=https://dummy@o0.ingest.sentry.io/0

# Sentry DSN for the browser bundle (src/lib/sentry.js). Vite inlines VITE_-prefixed
# vars into client code, so this value is public by design — a DSN is safe to expose.
# Leave unset to disable — the app runs normally without it.
VITE_SENTRY_DSN=https://dummy@o0.ingest.sentry.io/0

# Sentry API access for the triage script (.github/scripts/sentry-triage.mjs,
# `npm run sentry:triage`). SENTRY_AUTH_TOKEN needs Issues: Read & Write scope
# on an internal integration. Only needed to run the script locally — in CI
# these come from the SENTRY_AUTH_TOKEN secret and SENTRY_ORG/SENTRY_PROJECT
# repository variables (see .github/workflows/sentry-triage.yml). GITHUB_TOKEN
# is read from `gh auth token` when running locally with the gh CLI.
SENTRY_AUTH_TOKEN=dummy-sentry-internal-integration-token
SENTRY_ORG=threadsmiitit
SENTRY_PROJECT=javascript-react-1
